# Nature's Alchemy - Production Environment Variables Template
# Copy this file to .env in your production environment and fill in the values.
# NEVER commit the actual .env file to version control.

# Server configuration
PORT=5000
NODE_ENV=production

# Database configuration
# Path to your SQLite production database on persistent disk.
# Ensure file permissions restrict access to the application runner user only.
DATABASE_PATH=/var/lib/natures-alchemy/nature_alchemy.db

# JWT Security
# Set a high-entropy secret (e.g., generated via: openssl rand -base64 48)
JWT_SECRET=your_high_entropy_production_jwt_secret_here

# CORS Origin
# Multiple production origins are supported as a comma-separated list.
# Ensure no space is left around URLs if listing multiple origins.
CORS_ORIGIN=https://www.naturesalchemy.co,https://naturesalchemy.co

# Selcom Payment Gateway Configuration
# SELCOM_MODE must be set to 'mock', 'sandbox', or 'production' depending on cutover phase.
# Set to 'production' only after mock and sandbox payment/webhook/status verifications pass.
SELCOM_MODE=mock

# Selcom Sandbox/Production Base Gateway Endpoint
SELCOM_BASE_URL=https://sandbox.selcom.co/v1

# Selcom Webhook Receiver Endpoint (Must match server route path)
SELCOM_WEBHOOK_URL=https://yourdomain.com/api/webhooks/selcom

# Storefront Success/Cancel redirection paths
SELCOM_REDIRECT_URL=https://yourdomain.com/checkout/success
SELCOM_CANCEL_URL=https://yourdomain.com/checkout/cancel

# HTTP request timeout limit (in milliseconds)
SELCOM_REQUEST_TIMEOUT_MS=10000

# Selcom Production Credentials (Only when SELCOM_MODE is sandbox or production)
# Fill in with your official Selcom credentials. Keep safe and server-side only.
SELCOM_VENDOR_ID=your_selcom_vendor_id_here
SELCOM_API_KEY=your_selcom_api_key_here
SELCOM_API_SECRET=your_selcom_api_secret_here
SELCOM_PIN=your_selcom_pin_here

# Selcom Status Polling Throttling
# Minimum interval in milliseconds between provider order-status queries (default 30000ms)
SELCOM_STATUS_QUERY_MIN_INTERVAL_MS=30000

# Signed fields order configurations based strictly on official Selcom documentation.
# DO NOT include "timestamp" within any of these lists.
SELCOM_SIGNED_FIELDS_CREATE_ORDER_MINIMAL=vendor,order_id,buyer_email,buyer_name,buyer_phone,amount,currency,webhook,buyer_remarks,merchant_remarks,no_of_items
SELCOM_SIGNED_FIELDS_WALLET_PAYMENT=transid,order_id,msisdn
SELCOM_SIGNED_FIELDS_ORDER_STATUS=order_id
SELCOM_SIGNED_FIELDS_WEBHOOK=transid,order_id,reference,result,resultcode,payment_status
