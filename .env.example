# Nature's Alchemy - Backend Configuration
# Copy this file to .env and configure local values. 
# Do not commit the actual .env file or database files to version control.

# Server Port
PORT=5000

# CORS Whitelist Origin (Comma-separated for multiple origins)
# Wildcards (*) are strictly disallowed in production.
CORS_ORIGIN=http://localhost:5173

# SQLite Database Location
# Relative to server root or absolute path
DATABASE_PATH=./server/db/nature_alchemy.db

# Security & Limits
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Placeholder Secrets (Update with secure values in production)
JWT_SECRET=placeholder_jwt_secret_for_local_development_only_change_in_production
SESSION_SECRET=placeholder_session_secret_for_local_development_only_change_in_production

# Selcom Payment Gateway Configuration
SELCOM_BASE_URL=https://sandbox.selcom.co/v1
SELCOM_VENDOR_ID=placeholder_vendor_id
SELCOM_API_KEY=placeholder_api_key
SELCOM_API_SECRET=placeholder_api_secret
SELCOM_WEBHOOK_URL=https://yourdomain.com/api/webhooks/selcom
SELCOM_REDIRECT_URL=https://yourdomain.com/checkout/success
SELCOM_CANCEL_URL=https://yourdomain.com/checkout/cancel
SELCOM_REQUEST_TIMEOUT_MS=10000
SELCOM_STATUS_QUERY_MIN_INTERVAL_MS=30000

# Signed-Fields Lists (No timestamp inside Signed-Fields)
SELCOM_SIGNED_FIELDS_CREATE_ORDER_MINIMAL=vendor,order_id,buyer_email,buyer_name,buyer_phone,amount,currency,webhook,buyer_remarks,merchant_remarks,no_of_items
SELCOM_SIGNED_FIELDS_WALLET_PAYMENT=transid,order_id,msisdn
SELCOM_SIGNED_FIELDS_ORDER_STATUS=order_id
SELCOM_SIGNED_FIELDS_WEBHOOK=transid,order_id,reference,result,resultcode,payment_status

# SQL Logging Control (set to true to print raw SQL to console)
DEBUG_SQL=false
